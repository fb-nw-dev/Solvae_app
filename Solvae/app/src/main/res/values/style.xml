<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="btncad">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/btn_cad</item>
        <item name="android:text">@string/btn_cadastrar</item>
        <item name="android:layout_margin">20dp</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="editxtcad">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/edittext_cad</item>
        <item name="android:padding">20dp</item>
        <item name="android:layout_marginLeft">40dp</item>
        <item name="android:layout_marginRight">40dp</item>
        <item name="android:layout_marginTop">15dp</item>

    </style>

    <style name="btnllog">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">64dp</item>
        <item name="android:layout_marginTop">32dp</item>
        <item name="android:layout_marginEnd">64dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:background">@drawable/button_log</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:text">@string/btnlog</item>

    </style>

    <style name="edtlog">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:layout_marginStart">64dp</item>
        <item name="android:layout_marginTop">32dp</item>
        <item name="android:layout_marginEnd">64dp</item>
        <item name="android:background">@drawable/edttxt_log</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:hint">@string/edttxtlogin</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="edtpswdlog">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:layout_marginStart">64dp</item>
        <item name="android:layout_marginTop">32dp</item>
        <item name="android:layout_marginEnd">64dp</item>
        <item name="android:background">@drawable/edttxt_log</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:hint">@string/pswdlogin</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>